  endif()
  file(INSTALL DESTINATION "/usr/local/include/cjson" TYPE FILE FILES "/mnt/f/OneDrive/文档（科研）/脚本/Download/10-mtDNA/14-network/2-McAN/cJSON/cJSON.h")
